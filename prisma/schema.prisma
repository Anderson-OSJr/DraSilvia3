// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Lead {
  id        String   @id @default(cuid())
  nome      String
  whatsapp  String
  motivo    String
  createdAt DateTime @default(now())

  @@map("leads")
}
